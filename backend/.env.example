# ============================================================
# MERN Enterprise E-Commerce — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file — it is listed in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your real values

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=5001
NODE_ENV=development

# Public API URL (used in emails and webhooks)
API_URL=http://localhost:5001

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/enterprise-ecommerce

# MongoDB Atlas (replace with your connection string):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/enterprise-ecommerce?retryWrites=true&w=majority

# Separate test database (used when NODE_ENV=test)
MONGODB_TEST_URI=mongodb://localhost:27017/enterprise-ecommerce-test

# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------
# Generate strong secrets: openssl rand -hex 64
JWT_SECRET=replace_this_with_a_minimum_32_character_access_token_secret
JWT_EXPIRE=15m

JWT_REFRESH_SECRET=replace_this_with_a_different_minimum_32_character_refresh_secret
JWT_REFRESH_EXPIRE=7d

# ------------------------------------------------------------
# CORS / Frontend
# ------------------------------------------------------------
# Must match your frontend URL exactly (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Set to 1 when behind a reverse proxy (Railway, Render, etc.)
# TRUST_PROXY=1

# ------------------------------------------------------------
# Stripe Payments
# ------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key

# Get this from Stripe CLI or Stripe Dashboard -> Webhooks
# stripe listen --forward-to localhost:5001/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_signing_secret

# ------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------
# Gmail example (use App Password, not account password):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Sender address shown in outgoing emails
EMAIL_FROM=noreply@yourstore.com

# ------------------------------------------------------------
# Redis (required for background job queues)
# ------------------------------------------------------------
# Leave empty to disable queues; email and rating jobs will be skipped.
REDIS_URL=redis://localhost:6379
REDIS_DEFAULT_TTL=3600
QUEUE_CONCURRENCY=5

# ------------------------------------------------------------
# PayPal (placeholder - not fully implemented in v1.0.0)
# ------------------------------------------------------------
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox

# ------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------
# Maximum file upload size in bytes (default: 5 MB)
MAX_FILE_SIZE=5242880

# Allowed file extensions (comma-separated, no spaces)
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# Directory for uploaded files (relative to backend/)
UPLOAD_PATH=uploads

# ------------------------------------------------------------
# Admin Seeder Defaults
# ------------------------------------------------------------
# These credentials are used by the seeder to create the default admin account.
ADMIN_EMAIL=admin@enterprise-ecommerce.com
ADMIN_PASSWORD=admin123!

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_REFRESH_MAX=20
AUTH_RATE_LIMIT_FORGOT_PASSWORD_MAX=5
AUTH_RATE_LIMIT_RESET_PASSWORD_MAX=10

# ------------------------------------------------------------
# Performance Monitoring
# ------------------------------------------------------------
ENABLE_PERFORMANCE_MONITORING=true
SLOW_ROUTE_THRESHOLD_MS=800
SLOW_QUERY_THRESHOLD_MS=300
LATENCY_WINDOW_SIZE=200
LATENCY_REPORT_EVERY=100

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=info
