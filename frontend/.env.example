# ============================================================
# MERN Enterprise E-Commerce — Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit the .env file.
#
# Usage:
#   cp .env.example .env

# ------------------------------------------------------------
# API Connection
# ------------------------------------------------------------
# Full base URL of the backend server — no trailing slash, no /api suffix.
# The /api prefix is added by endpoint constants in the frontend code.
# Development:
VITE_API_BASE_URL=http://localhost:5001

# Production example:
# VITE_API_BASE_URL=https://your-backend.railway.app

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------
# Stripe publishable key — safe to expose (not the secret key).
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key
